{
  "name": "@homeflow/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types, constants, and utilities for HomeFlow",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0"
  },
  "keywords": ["homeflow", "types", "shared"],
  "license": "UNLICENSED",
  "private": true
}
